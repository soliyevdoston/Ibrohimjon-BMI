# Copy to .env.local for local dev, OR set these on your hosting
# platform (Vercel/Render) for production builds.
#
# Local dev:
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# NEXT_PUBLIC_WS_URL=http://localhost:4000
#
# Production (deployed backend on Render):
NEXT_PUBLIC_API_URL=https://ibrohimjon-bmi.onrender.com/api/v1
NEXT_PUBLIC_WS_URL=https://ibrohimjon-bmi.onrender.com

# MapTiler key for the map components (get one at https://maptiler.com)
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key-here
