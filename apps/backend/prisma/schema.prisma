generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SELLER
  COURIER
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  COURIER_ACCEPTED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  CANCELED
  FAILED
}

enum PaymentStatus {
  CREATED
  PROCESSING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum DeliveryStatus {
  SEARCHING_COURIER
  ACCEPTED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  FAILED
  CANCELED
}

enum OtpPurpose {
  LOGIN
  PHONE_VERIFY
}

model User {
  id              String          @id @default(uuid())
  phone           String          @unique
  fullName        String?
  role            UserRole
  status          UserStatus      @default(ACTIVE)
  isPhoneVerified Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  sellerProfile   Seller?
  courierProfile  Courier?
  customerOrders  Order[]         @relation("CustomerOrders")
  otpCodes        OtpCode[]
  refreshTokens   RefreshToken[]

  @@index([role, status])
}

model Seller {
  id                String      @id @default(uuid())
  userId            String      @unique
  legalName         String
  brandName         String
  description       String?
  isActive          Boolean     @default(true)
  rating            Float       @default(5.0)
  addressText       String?
  addressLat        Decimal?    @db.Decimal(9, 6)
  addressLng        Decimal?    @db.Decimal(9, 6)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id])
  products          Product[]
  orders            Order[]

  @@index([isActive])
}

model Courier {
  id                String            @id @default(uuid())
  userId            String            @unique
  vehicleType       String?
  isOnline          Boolean           @default(false)
  isAvailable       Boolean           @default(false)
  currentLat        Decimal?          @db.Decimal(9, 6)
  currentLng        Decimal?          @db.Decimal(9, 6)
  lastSeenAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user              User              @relation(fields: [userId], references: [id])
  deliveries        Delivery[]
  locations         CourierLocation[]

  @@index([isOnline, isAvailable])
}

model Category {
  id          String      @id @default(uuid())
  name        String      @unique
  slug        String      @unique
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  products    Product[]
}

model Product {
  id                String      @id @default(uuid())
  sellerId          String
  categoryId        String
  title             String
  description       String?
  imageUrl          String?
  price             Decimal     @db.Decimal(12, 2)
  stock             Int
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  seller            Seller      @relation(fields: [sellerId], references: [id])
  category          Category    @relation(fields: [categoryId], references: [id])
  orderItems        OrderItem[]

  @@index([sellerId, isActive])
  @@index([categoryId])
  @@index([price])
}

model Order {
  id                    String               @id @default(uuid())
  customerId            String
  sellerId              String
  status                OrderStatus          @default(PENDING)
  statusChangedAt       DateTime             @default(now())
  idempotencyKey        String               @unique
  subtotalAmount        Decimal              @db.Decimal(12, 2)
  deliveryFeeAmount     Decimal              @db.Decimal(12, 2)
  totalAmount           Decimal              @db.Decimal(12, 2)
  paymentMethod         String
  paymentStatus         PaymentStatus        @default(CREATED)
  note                  String?
  deliveryAddressText   String
  deliveryLat           Decimal              @db.Decimal(9, 6)
  deliveryLng           Decimal              @db.Decimal(9, 6)
  estimatedDeliveryAt   DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  customer              User                 @relation("CustomerOrders", fields: [customerId], references: [id])
  seller                Seller               @relation(fields: [sellerId], references: [id])
  items                 OrderItem[]
  payment               Payment?
  delivery              Delivery?
  statusHistory         OrderStatusHistory[]

  @@index([customerId, createdAt(sort: Desc)])
  @@index([sellerId, status])
  @@index([status, createdAt])
}

model OrderItem {
  id                String      @id @default(uuid())
  orderId           String
  productId         String
  titleSnapshot     String
  priceSnapshot     Decimal     @db.Decimal(12, 2)
  quantity          Int
  totalAmount       Decimal     @db.Decimal(12, 2)

  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product     @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                  String          @id @default(uuid())
  orderId             String          @unique
  provider            String
  externalPaymentId   String?
  callbackIdempotency String?         @unique
  amount              Decimal         @db.Decimal(12, 2)
  status              PaymentStatus   @default(CREATED)
  redirectUrl         String?
  failReason          String?
  rawCallbackPayload  Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([externalPaymentId])
}

model Delivery {
  id                String          @id @default(uuid())
  orderId           String          @unique
  courierId         String?
  status            DeliveryStatus  @default(SEARCHING_COURIER)
  distanceKm        Decimal?        @db.Decimal(8, 2)
  etaMinutes        Int?
  acceptedAt        DateTime?
  pickedUpAt        DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courier           Courier?        @relation(fields: [courierId], references: [id])
  locations         CourierLocation[]

  @@index([courierId, status])
  @@index([status, createdAt])
}

model CourierLocation {
  id                String      @id @default(uuid())
  courierId         String
  deliveryId        String
  lat               Decimal     @db.Decimal(9, 6)
  lng               Decimal     @db.Decimal(9, 6)
  speedMps          Decimal?    @db.Decimal(7, 2)
  headingDeg        Decimal?    @db.Decimal(6, 2)
  capturedAt        DateTime    @default(now())

  courier           Courier     @relation(fields: [courierId], references: [id], onDelete: Cascade)
  delivery          Delivery    @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, capturedAt])
  @@index([courierId, capturedAt])
}

model OrderStatusHistory {
  id                String        @id @default(uuid())
  orderId           String
  status            OrderStatus
  actorUserId       String?
  note              String?
  createdAt         DateTime      @default(now())

  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model OtpCode {
  id                String      @id @default(uuid())
  userId            String?
  phone             String
  purpose           OtpPurpose
  codeHash          String
  attemptCount      Int         @default(0)
  expiresAt         DateTime
  consumedAt        DateTime?
  resendCount       Int         @default(0)
  ipAddress         String?
  createdAt         DateTime    @default(now())

  user              User?       @relation(fields: [userId], references: [id])

  @@index([phone, purpose, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model RefreshToken {
  id                String      @id @default(uuid())
  userId            String
  tokenHash         String      @unique
  userAgent         String?
  ipAddress         String?
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime    @default(now())

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
