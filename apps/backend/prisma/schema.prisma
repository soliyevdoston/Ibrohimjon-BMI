generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SELLER
  COURIER
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  COURIER_ACCEPTED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  CANCELED
  FAILED
}

enum PaymentStatus {
  CREATED
  PROCESSING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum DeliveryStatus {
  SEARCHING_COURIER
  ACCEPTED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  FAILED
  CANCELED
}

enum OtpPurpose {
  LOGIN
  PHONE_VERIFY
}

enum LedgerEntryType {
  SELLER_PAYOUT
  COMMISSION
  COURIER_FEE
  DELIVERY_MARGIN
  SERVICE_FEE
  REFUND
}

enum LedgerPayeeType {
  PLATFORM
  SELLER
  COURIER
}

enum LedgerEntryStatus {
  PENDING
  AVAILABLE
  PAID_OUT
  REVERSED
}

enum PayoutPayeeType {
  SELLER
  COURIER
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum CardProvider {
  UZCARD
  HUMO
  VISA
  MASTERCARD
  UNKNOWN
}

enum VehicleType {
  BIKE
  CAR
  VAN
  TRUCK
}

model User {
  id              String     @id @default(uuid())
  phone           String?    @unique
  email           String?    @unique
  passwordHash    String?
  fullName        String?
  role            UserRole
  status          UserStatus @default(ACTIVE)
  isPhoneVerified Boolean    @default(false)
  isEmailVerified Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  sellerProfile  Seller?
  courierProfile Courier?
  customerOrders Order[]        @relation("CustomerOrders")
  customerCards  CustomerCard[]
  otpCodes       OtpCode[]
  refreshTokens  RefreshToken[]

  @@index([role, status])
}

model Seller {
  id             String   @id @default(uuid())
  userId         String   @unique
  legalName      String
  brandName      String
  description    String?
  isActive       Boolean  @default(true)
  rating         Float    @default(5.0)
  addressText    String?
  addressLat     Decimal? @db.Decimal(9, 6)
  addressLng     Decimal? @db.Decimal(9, 6)
  commissionRate Decimal  @default(0.10) @db.Decimal(5, 4)
  bankCardNumber String?
  bankCardHolder String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  products Product[]
  orders   Order[]

  @@index([isActive])
}

model Courier {
  id             String      @id @default(uuid())
  userId         String      @unique
  vehicleType    VehicleType @default(BIKE)
  vehicleModel   String?
  vehiclePlate   String?
  maxLoadKg      Decimal     @default(10) @db.Decimal(8, 2)
  isOnline       Boolean     @default(false)
  isAvailable    Boolean     @default(false)
  currentLat     Decimal?    @db.Decimal(9, 6)
  currentLng     Decimal?    @db.Decimal(9, 6)
  lastSeenAt     DateTime?
  bankCardNumber String?
  bankCardHolder String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user       User              @relation(fields: [userId], references: [id])
  deliveries Delivery[]
  locations  CourierLocation[]

  @@index([isOnline, isAvailable])
  @@index([vehicleType, isAvailable])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id              String      @id @default(uuid())
  sellerId        String
  categoryId      String
  title           String
  description     String?
  imageUrl        String?
  price           Decimal     @db.Decimal(12, 2)
  stock           Int
  weightKg        Decimal     @default(1) @db.Decimal(8, 2)
  dimensionsCm    String?
  requiresVehicle VehicleType @default(BIKE)
  isFragile       Boolean     @default(false)
  isOversized     Boolean     @default(false)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  seller     Seller      @relation(fields: [sellerId], references: [id])
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([sellerId, isActive])
  @@index([categoryId])
  @@index([price])
  @@index([requiresVehicle])
}

model Order {
  id                       String        @id @default(uuid())
  customerId               String
  sellerId                 String
  status                   OrderStatus   @default(PENDING)
  statusChangedAt          DateTime      @default(now())
  idempotencyKey           String        @unique
  subtotalAmount           Decimal       @db.Decimal(12, 2)
  deliveryFeeAmount        Decimal       @db.Decimal(12, 2)
  serviceFeeAmount         Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount              Decimal       @db.Decimal(12, 2)
  platformCommissionAmount Decimal       @default(0) @db.Decimal(12, 2)
  courierFeeAmount         Decimal       @default(0) @db.Decimal(12, 2)
  sellerPayoutAmount       Decimal       @default(0) @db.Decimal(12, 2)
  platformRevenueAmount    Decimal       @default(0) @db.Decimal(12, 2)
  commissionRateSnapshot   Decimal       @default(0.10) @db.Decimal(5, 4)
  paymentMethod            String
  paymentStatus            PaymentStatus @default(CREATED)
  customerCardId           String?
  requiredVehicle          VehicleType   @default(BIKE)
  totalWeightKg            Decimal       @default(0) @db.Decimal(10, 2)
  note                     String?
  deliveryAddressText      String
  deliveryLat              Decimal       @db.Decimal(9, 6)
  deliveryLng              Decimal       @db.Decimal(9, 6)
  estimatedDeliveryAt      DateTime?
  deliveredAt              DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  customer      User                 @relation("CustomerOrders", fields: [customerId], references: [id])
  seller        Seller               @relation(fields: [sellerId], references: [id])
  customerCard  CustomerCard?        @relation(fields: [customerCardId], references: [id])
  items         OrderItem[]
  payment       Payment?
  delivery      Delivery?
  statusHistory OrderStatusHistory[]
  ledgerEntries LedgerEntry[]

  @@index([customerId, createdAt(sort: Desc)])
  @@index([sellerId, status])
  @@index([status, createdAt])
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String
  titleSnapshot String
  priceSnapshot Decimal @db.Decimal(12, 2)
  quantity      Int
  totalAmount   Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                  String        @id @default(uuid())
  orderId             String        @unique
  provider            String
  externalPaymentId   String?
  callbackIdempotency String?       @unique
  amount              Decimal       @db.Decimal(12, 2)
  status              PaymentStatus @default(CREATED)
  redirectUrl         String?
  failReason          String?
  rawCallbackPayload  Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([externalPaymentId])
}

model Delivery {
  id          String         @id @default(uuid())
  orderId     String         @unique
  courierId   String?
  status      DeliveryStatus @default(SEARCHING_COURIER)
  distanceKm  Decimal?       @db.Decimal(8, 2)
  etaMinutes  Int?
  acceptedAt  DateTime?
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courier   Courier?          @relation(fields: [courierId], references: [id])
  locations CourierLocation[]

  @@index([courierId, status])
  @@index([status, createdAt])
}

model CourierLocation {
  id         String   @id @default(uuid())
  courierId  String
  deliveryId String
  lat        Decimal  @db.Decimal(9, 6)
  lng        Decimal  @db.Decimal(9, 6)
  speedMps   Decimal? @db.Decimal(7, 2)
  headingDeg Decimal? @db.Decimal(6, 2)
  capturedAt DateTime @default(now())

  courier  Courier  @relation(fields: [courierId], references: [id], onDelete: Cascade)
  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, capturedAt])
  @@index([courierId, capturedAt])
}

model OrderStatusHistory {
  id          String      @id @default(uuid())
  orderId     String
  status      OrderStatus
  actorUserId String?
  note        String?
  createdAt   DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model OtpCode {
  id           String     @id @default(uuid())
  userId       String?
  phone        String
  purpose      OtpPurpose
  codeHash     String
  attemptCount Int        @default(0)
  expiresAt    DateTime
  consumedAt   DateTime?
  resendCount  Int        @default(0)
  ipAddress    String?
  createdAt    DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([phone, purpose, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model LedgerEntry {
  id          String            @id @default(uuid())
  orderId     String
  type        LedgerEntryType
  payeeType   LedgerPayeeType
  payeeId     String?
  amount      Decimal           @db.Decimal(12, 2)
  status      LedgerEntryStatus @default(PENDING)
  availableAt DateTime?
  paidOutAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payoutItem PayoutItem?

  @@index([payeeType, payeeId, status])
  @@index([orderId, type])
  @@index([status, createdAt])
}

model Payout {
  id                     String          @id @default(uuid())
  payeeType              PayoutPayeeType
  payeeId                String
  amount                 Decimal         @db.Decimal(12, 2)
  status                 PayoutStatus    @default(PENDING)
  bankCardSnapshot       String?
  bankCardHolderSnapshot String?
  note                   String?
  rejectionReason        String?
  processedByUserId      String?
  requestedAt            DateTime        @default(now())
  processedAt            DateTime?

  items PayoutItem[]

  @@index([payeeType, payeeId, requestedAt(sort: Desc)])
  @@index([status, requestedAt])
}

model PayoutItem {
  id            String  @id @default(uuid())
  payoutId      String
  ledgerEntryId String  @unique
  amount        Decimal @db.Decimal(12, 2)

  payout      Payout      @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  ledgerEntry LedgerEntry @relation(fields: [ledgerEntryId], references: [id])

  @@index([payoutId])
}

model PlatformConfig {
  id                  String   @id @default("default")
  commissionRate      Decimal  @default(0.10) @db.Decimal(5, 4)
  serviceFeeRate      Decimal  @default(0.02) @db.Decimal(5, 4)
  // BIKE tier (default for small items)
  deliveryBaseFee     Decimal  @default(6000) @db.Decimal(12, 2)
  deliveryPerKmFee    Decimal  @default(1400) @db.Decimal(12, 2)
  courierBaseFee      Decimal  @default(5000) @db.Decimal(12, 2)
  courierPerKmFee     Decimal  @default(1200) @db.Decimal(12, 2)
  // CAR tier (small/medium loads, ~25 kg)
  carBaseFee          Decimal  @default(15000) @db.Decimal(12, 2)
  carPerKmFee         Decimal  @default(2000) @db.Decimal(12, 2)
  carCourierBase      Decimal  @default(12000) @db.Decimal(12, 2)
  carCourierPerKm     Decimal  @default(1700) @db.Decimal(12, 2)
  // VAN tier (medium loads ~200 kg)
  vanBaseFee          Decimal  @default(35000) @db.Decimal(12, 2)
  vanPerKmFee         Decimal  @default(3500) @db.Decimal(12, 2)
  vanCourierBase      Decimal  @default(28000) @db.Decimal(12, 2)
  vanCourierPerKm     Decimal  @default(2900) @db.Decimal(12, 2)
  // TRUCK tier (heavy loads, mebel/qurilish)
  truckBaseFee        Decimal  @default(70000) @db.Decimal(12, 2)
  truckPerKmFee       Decimal  @default(5500) @db.Decimal(12, 2)
  truckCourierBase    Decimal  @default(55000) @db.Decimal(12, 2)
  truckCourierPerKm   Decimal  @default(4500) @db.Decimal(12, 2)
  // Vehicle thresholds (kg)
  bikeMaxKg           Decimal  @default(10) @db.Decimal(8, 2)
  carMaxKg            Decimal  @default(50) @db.Decimal(8, 2)
  vanMaxKg            Decimal  @default(300) @db.Decimal(8, 2)
  updatedAt           DateTime @updatedAt
}

model CustomerCard {
  id            String       @id @default(uuid())
  userId        String
  last4         String
  holderName    String
  provider      CardProvider @default(UNKNOWN)
  expiryMonth   Int
  expiryYear    Int
  isDefault     Boolean      @default(false)
  isActive      Boolean      @default(true)
  providerToken String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId, isActive])
  @@index([userId, isDefault])
}
