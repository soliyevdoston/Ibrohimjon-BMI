NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/delivery
JWT_ACCESS_SECRET=super-access-secret
JWT_REFRESH_SECRET=super-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
OTP_TTL_SECONDS=120
OTP_RETRY_LIMIT=5
REDIS_URL=redis://localhost:6379
PAYMENT_CALLBACK_SECRET=change-me
DELIVERY_BASE_FEE=6000
DELIVERY_PER_KM_FEE=1400

# Google Sign-In — Web client ID (https://console.cloud.google.com/apis/credentials).
# Frontend va backend bir xil Client ID dan foydalaning. Authorized JavaScript
# origins'ga customer app domeni qo'shilgan bo'lishi shart.
GOOGLE_CLIENT_ID=
